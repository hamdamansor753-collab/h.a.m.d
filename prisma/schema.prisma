// ====================================================================
// H.A.M.D ERP — Core Data Model
// Implements /upload/04-data-model.md + all phase additions.
// ====================================================================
// DATABASE:
//   Production: PostgreSQL (Supabase) with native Row-Level Security.
//   The RLS SQL file at prisma/sql/tenant_rls_postgres.sql enables
//   RLS on all 14 tenant-scoped tables. The Prisma Proxy in db.ts
//   is the FIRST isolation layer; RLS is the SECOND (defense in depth).
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ================= CORE: TENANCY =================

model Tenant {
  id            String    @id @default(uuid())
  name          String
  defaultLocale String    @default("ar-EG")
  country       String // "EG" | "SA" | "AE" — selects Tax Provider
  createdAt     DateTime  @default(now())
  users         User[]
  accounts      Account[]
  journalEntries JournalEntry[]
  invoices      Invoice[]
  warehouses    Warehouse[]
  products      Product[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  employees     Employee[]
  payrollRuns   PayrollRun[]
  customers     Customer[]
  appointments  Appointment[]
  activityLogs  ActivityLog[]
}

model User {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  email           String
  name            String
  // Hashed password (bcrypt). Never stored or logged in plaintext.
  passwordHash    String
  locale          String     @default("ar-EG")
  roles           UserRole[]
  createdAt       DateTime   @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // "admin" | "accountant" | "viewer"
  permissions Permission[]
  users       UserRole[]
}

model Permission {
  id     String @id @default(uuid())
  key    String @unique // "account:read" | "journal:create" | ...
  roles  Role[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ================= CORE: LEDGER (Double-Entry) =================

model Account {
  // Chart of Accounts — tree-structured
  id        String      @id @default(uuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  code      String // "1000", "1000.01" ...
  nameKey   String // translation key — never raw text
  type      AccountType
  parentId  String?
  parent    Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children  Account[]   @relation("AccountHierarchy")
  lines     JournalLine[]
  createdAt DateTime    @default(now())

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  // Every financial movement in the system lands here — no exceptions.
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  date         DateTime
  description  String
  sourceModule String        // "accounting" | "inventory" | "pos" | "hr"
  sourceRefId  String        // ID of the originating document in source module
  lines        JournalLine[]
  // Back-relation: the invoice (if any) that generated this entry on posting.
  // Null for manually-created entries and for voiding reversal entries.
  postedInvoice Invoice?
  // Back-relation: the invoice (if any) that this entry voided.
  voidedInvoice Invoice? @relation("InvoiceVoidEntry")
  // Back-relation: stock movements (purchase receipt, sale COGS) linked to this entry.
  stockMovements StockMovement[]
  // Back-relation: the purchase order (if any) that generated this entry on receipt.
  receivedPurchaseOrder PurchaseOrder?
  // Back-relation: the payroll run (if any) that generated this entry on posting.
  postedPayrollRun PayrollRun?
  createdAt    DateTime      @default(now())

  @@index([tenantId, date])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)

  @@index([accountId])
  @@index([journalEntryId])
}
// MANDATORY: SUM(debit) === SUM(credit) for every JournalEntry.
// Enforced in service layer (src/core/ledger/journal-entry.service.ts)
// BEFORE any DB write — see test in /api/tests/journal-balance.

// ================= CORE: i18n =================

model Translation {
  id     String @id @default(uuid())
  key    String // "invoice.title"
  locale String // "ar-EG" | "ar-SA" | "en"
  value  String

  @@unique([key, locale])
  @@index([locale])
}

// ================= PHASE 1: ACCOUNTING & INVOICING =================

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  number         String        // sequential per tenant, non-reusable
  customerName   String
  date           DateTime
  status         InvoiceStatus @default(DRAFT)
  channel        InvoiceChannel @default(MANUAL) // "MANUAL" | "POS" — distinguishes POS sales
  lines          InvoiceLine[]
  // Filled on posting — links to the JournalEntry that recorded this invoice
  // in the ledger. Null while DRAFT, set when POSTED, kept (not nulled) on VOID.
  journalEntryId String? @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  // Filled on voiding — the reversing JournalEntry. Null unless VOID.
  voidJournalEntryId String? @unique
  voidJournalEntry   JournalEntry? @relation("InvoiceVoidEntry", fields: [voidJournalEntryId], references: [id])
  // Phase 5: optional link to a Customer record (null for walk-in/anonymous sales)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt      DateTime      @default(now())

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum InvoiceStatus {
  DRAFT
  POSTED // posted to ledger — immutable after this point
  VOID   // voided with a reversing entry — original entry stays for audit
}

enum InvoiceChannel {
  MANUAL // created manually via the invoicing module (credit sale, debits AR)
  POS    // created via POS (cash sale, debits Cash)
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal
  taxRate     Decimal @default(0) // per-line rate (0.14 = 14%)
}

// ================= PHASE 2: INVENTORY & PURCHASING =================

model Warehouse {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  nameKey     String       // translation key — never raw text
  isDefault   Boolean      @default(false)
  stockLevels StockLevel[]
  createdAt   DateTime     @default(now())

  @@index([tenantId])
}

model Product {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  sku         String
  nameKey     String       // translation key — never raw text
  costPrice   Decimal      @default(0) // weighted-average cost — updated on receipts
  sellPrice   Decimal      @default(0)
  stockLevels StockLevel[]
  createdAt   DateTime     @default(now())

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model StockLevel {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Decimal   @default(0)

  @@unique([productId, warehouseId])
}

model StockMovement {
  // Append-only audit trail. NEVER edited or deleted — every stock change
  // creates a new row. StockLevel.quantity is a DERIVED value kept in sync
  // by the stock-movement service inside the same transaction.
  id            String            @id @default(uuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  productId     String
  warehouseId   String
  type          StockMovementType
  quantity      Decimal           // always positive; direction determined by `type`
  unitCost      Decimal           // cost per unit at time of movement (for COGS accuracy)
  sourceModule  String            // "purchase" | "sales" | "adjustment" | "transfer"
  sourceRefId   String            // ID of the originating document
  journalEntryId String?  // filled if the movement generated a ledger entry (multiple movements can share one JE)
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  createdAt     DateTime          @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
}

enum StockMovementType {
  RECEIPT      // stock in from supplier (purchase order receipt)
  SALE         // stock out for a sale
  TRANSFER_IN  // stock in from another warehouse
  TRANSFER_OUT // stock out to another warehouse
  ADJUSTMENT   // inventory count adjustment (can be +/-)
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  number        String              // sequential per tenant, non-reusable
  supplierName  String
  date          DateTime
  status        PurchaseOrderStatus @default(DRAFT)
  lines         PurchaseOrderLine[]
  // Filled on receive — the JournalEntry recording the inventory + AP entry.
  journalEntryId String? @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt     DateTime            @default(now())

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum PurchaseOrderStatus {
  DRAFT
  RECEIVED   // goods received — StockMovement(RECEIPT) + ledger entry created
  CANCELLED
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  quantity        Decimal
  unitCost        Decimal
  warehouseId     String
}

// ================= PHASE 4: HR & PAYROLL =================

model Employee {
  id           String         @id @default(uuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  fullName     String
  nationalId   String         // الرقم القومي/الهوية — بيانات حساسة (لا تُسجَّل في logs)
  hireDate     DateTime
  baseSalary   Decimal        // بيانات حساسة — تتطلب hr:salary:read
  status       EmployeeStatus @default(ACTIVE)
  payrollLines PayrollLine[]
  createdAt    DateTime       @default(now())

  @@index([tenantId])
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

model PayrollRun {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  period         String       // "2026-07" — YYYY-MM
  status         PayrollStatus @default(DRAFT)
  lines          PayrollLine[]
  // Filled on posting — links to the JournalEntry recording the payroll.
  journalEntryId String? @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([tenantId, period])
  @@index([tenantId])
}

enum PayrollStatus {
  DRAFT
  POSTED // posted to ledger — immutable after this point
}

model PayrollLine {
  id               String    @id @default(uuid())
  payrollRunId     String
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id])
  grossSalary      Decimal
  incomeTax        Decimal   @default(0)  // from PayrollRuleProvider
  employeeInsurance Decimal  @default(0)  // employee's share
  employerInsurance Decimal  @default(0)  // employer's share (extra cost, not deducted from employee)
  netPay           Decimal                // = grossSalary - incomeTax - employeeInsurance
}

// ================= PHASE 5: CRM =================

model Customer {
  id           String       @id @default(uuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  name         String
  phone        String?
  email        String?
  invoices     Invoice[]
  appointments Appointment[]
  activities   ActivityLog[]
  createdAt    DateTime     @default(now())

  @@index([tenantId])
}

model Appointment {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  customerId  String
  customer    Customer          @relation(fields: [customerId], references: [id])
  scheduledAt DateTime
  note        String?
  status      AppointmentStatus @default(SCHEDULED)
  reminders   Reminder[]

  @@index([tenantId, scheduledAt])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reminder {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  dueAt         DateTime
  sent          Boolean     @default(false)
  channel       String      // "in_app" only in Phase 5 — SMS/WhatsApp future module

  @@index([dueAt, sent])
}

model ActivityLog {
  // Append-only audit trail — never edited after creation.
  // Created automatically by invoice.service + appointment.service.
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   // "invoice_created" | "appointment_scheduled" | ...
  refId      String   // ID of the linked invoice/appointment
  createdAt  DateTime @default(now())

  @@index([tenantId, customerId])
}

// ================= PRODUCTION HARDENING: SEQUENCE COUNTER =================

model SequenceCounter {
  tenantId    String
  sequenceKey String   // "invoice" | "purchase_order" | ...
  lastValue   Int      @default(0)

  @@id([tenantId, sequenceKey])
}
