generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Account {
  id            String        @id @default(uuid())
  tenantId      String
  code          String
  nameKey       String
  type          AccountType
  parentId      String?
  createdAt     DateTime      @default(now())
  Account       Account?      @relation("AccountToAccount", fields: [parentId], references: [id])
  other_Account Account[]     @relation("AccountToAccount")
  Tenant        Tenant        @relation(fields: [tenantId], references: [id])
  JournalLine   JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ActivityLog {
  id         String   @id @default(uuid())
  tenantId   String
  customerId String
  type       String
  refId      String
  createdAt  DateTime @default(now())
  Customer   Customer @relation(fields: [customerId], references: [id])
  Tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, customerId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Appointment {
  id          String            @id @default(uuid())
  tenantId    String
  customerId  String
  scheduledAt DateTime
  note        String?
  status      AppointmentStatus @default(SCHEDULED)
  Customer    Customer          @relation(fields: [customerId], references: [id])
  Tenant      Tenant            @relation(fields: [tenantId], references: [id])
  Reminder    Reminder[]

  @@index([tenantId, scheduledAt])
}

model BOMComponent {
  id                   String          @id @default(uuid())
  bomId                String
  rawMaterialProductId String
  quantityPerUnit      Decimal
  BillOfMaterials      BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  Product              Product         @relation(fields: [rawMaterialProductId], references: [id])
}

model BillOfMaterials {
  id                String         @id @default(uuid())
  tenantId          String
  finishedProductId String
  laborCostPerUnit  Decimal        @default(0)
  BOMComponent      BOMComponent[]
  Product           Product        @relation(fields: [finishedProductId], references: [id])

  @@unique([tenantId, finishedProductId])
  @@index([tenantId])
}

model BrandSettings {
  tenantId          String   @id
  logoUrl           String?
  primaryColor      String   @default("#0f172a")
  accentColor       String   @default("#06b6d4")
  invoiceFooterText String?
  updatedAt         DateTime
  Tenant            Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Customer {
  id          String        @id @default(uuid())
  tenantId    String
  name        String
  phone       String?
  email       String?
  createdAt   DateTime      @default(now())
  ActivityLog ActivityLog[]
  Appointment Appointment[]
  Tenant      Tenant        @relation(fields: [tenantId], references: [id])
  Invoice     Invoice[]

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Employee {
  id          String         @id @default(uuid())
  tenantId    String
  fullName    String
  nationalId  String
  hireDate    DateTime
  baseSalary  Decimal
  status      EmployeeStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  Tenant      Tenant         @relation(fields: [tenantId], references: [id])
  PayrollLine PayrollLine[]

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Invoice {
  id                                                    String         @id @default(uuid())
  tenantId                                              String
  number                                                String
  customerName                                          String
  date                                                  DateTime
  status                                                InvoiceStatus  @default(DRAFT)
  channel                                               InvoiceChannel @default(MANUAL)
  journalEntryId                                        String?        @unique
  voidJournalEntryId                                    String?        @unique
  customerId                                            String?
  createdAt                                             DateTime       @default(now())
  Customer                                              Customer?      @relation(fields: [customerId], references: [id])
  JournalEntry_Invoice_journalEntryIdToJournalEntry     JournalEntry?  @relation("Invoice_journalEntryIdToJournalEntry", fields: [journalEntryId], references: [id])
  Tenant                                                Tenant         @relation(fields: [tenantId], references: [id])
  JournalEntry_Invoice_voidJournalEntryIdToJournalEntry JournalEntry?  @relation("Invoice_voidJournalEntryIdToJournalEntry", fields: [voidJournalEntryId], references: [id])
  InvoiceLine                                           InvoiceLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  amount      Decimal
  taxRate     Decimal @default(0)
  Invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model JournalEntry {
  id                                               String           @id @default(uuid())
  tenantId                                         String
  date                                             DateTime
  description                                      String
  sourceModule                                     String
  sourceRefId                                      String
  createdAt                                        DateTime         @default(now())
  Invoice_Invoice_journalEntryIdToJournalEntry     Invoice?         @relation("Invoice_journalEntryIdToJournalEntry")
  Invoice_Invoice_voidJournalEntryIdToJournalEntry Invoice?         @relation("Invoice_voidJournalEntryIdToJournalEntry")
  Tenant                                           Tenant           @relation(fields: [tenantId], references: [id])
  JournalLine                                      JournalLine[]
  PayrollRun                                       PayrollRun?
  ProductionOrder                                  ProductionOrder?
  PurchaseOrder                                    PurchaseOrder?
  StockMovement                                    StockMovement[]

  @@index([tenantId, date])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  Account        Account      @relation(fields: [accountId], references: [id])
  JournalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([journalEntryId])
}

model PaymentRecord {
  id               String       @id @default(uuid())
  subscriptionId   String
  amount           Decimal
  method           String
  recordedByUserId String
  periodExtendedTo DateTime
  createdAt        DateTime     @default(now())
  Subscription     Subscription @relation(fields: [subscriptionId], references: [id])
}

model PayrollLine {
  id                String     @id @default(uuid())
  payrollRunId      String
  employeeId        String
  grossSalary       Decimal
  incomeTax         Decimal    @default(0)
  employeeInsurance Decimal    @default(0)
  employerInsurance Decimal    @default(0)
  netPay            Decimal
  Employee          Employee   @relation(fields: [employeeId], references: [id])
  PayrollRun        PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PayrollRun {
  id             String        @id @default(uuid())
  tenantId       String
  period         String
  status         PayrollStatus @default(DRAFT)
  journalEntryId String?       @unique
  createdAt      DateTime      @default(now())
  PayrollLine    PayrollLine[]
  JournalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  Tenant         Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, period])
  @@index([tenantId])
}

model Permission {
  id   String @id @default(uuid())
  key  String @unique
  Role Role[]
}

model Plan {
  id                  String         @id @default(uuid())
  key                 String         @unique
  nameKey             String
  monthlyPrice        Decimal
  maxUsers            Int
  maxInvoicesPerMonth Int?
  Subscription        Subscription[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Product {
  id              String            @id @default(uuid())
  tenantId        String
  sku             String
  nameKey         String
  costPrice       Decimal           @default(0)
  sellPrice       Decimal           @default(0)
  createdAt       DateTime          @default(now())
  BOMComponent    BOMComponent[]
  BillOfMaterials BillOfMaterials[]
  Tenant          Tenant            @relation(fields: [tenantId], references: [id])
  StockLevel      StockLevel[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model ProductionOrder {
  id                String                @id @default(uuid())
  tenantId          String
  finishedProductId String
  quantity          Decimal
  warehouseId       String
  status            ProductionOrderStatus @default(DRAFT)
  totalMaterialCost Decimal?
  totalLaborCost    Decimal?
  journalEntryId    String?               @unique
  createdAt         DateTime              @default(now())
  JournalEntry      JournalEntry?         @relation(fields: [journalEntryId], references: [id])

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PurchaseOrder {
  id                String              @id @default(uuid())
  tenantId          String
  number            String
  supplierName      String
  date              DateTime
  status            PurchaseOrderStatus @default(DRAFT)
  journalEntryId    String?             @unique
  createdAt         DateTime            @default(now())
  JournalEntry      JournalEntry?       @relation(fields: [journalEntryId], references: [id])
  Tenant            Tenant              @relation(fields: [tenantId], references: [id])
  PurchaseOrderLine PurchaseOrderLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal
  unitCost        Decimal
  warehouseId     String
  PurchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Reminder {
  id            String      @id @default(uuid())
  appointmentId String
  dueAt         DateTime
  sent          Boolean     @default(false)
  channel       String
  Appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([dueAt, sent])
}

model Role {
  id         String       @id @default(uuid())
  name       String       @unique
  UserRole   UserRole[]
  Permission Permission[]
}

model SequenceCounter {
  tenantId    String
  sequenceKey String
  lastValue   Int    @default(0)

  @@id([tenantId, sequenceKey])
}

model StockLevel {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  quantity    Decimal   @default(0)
  Product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  Warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StockMovement {
  id             String            @id @default(uuid())
  tenantId       String
  productId      String
  warehouseId    String
  type           StockMovementType
  quantity       Decimal
  unitCost       Decimal
  sourceModule   String
  sourceRefId    String
  journalEntryId String?
  createdAt      DateTime          @default(now())
  JournalEntry   JournalEntry?     @relation(fields: [journalEntryId], references: [id])
  Tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime
  trialEndsAt      DateTime?
  createdAt        DateTime           @default(now())
  PaymentRecord    PaymentRecord[]
  Plan             Plan               @relation(fields: [planId], references: [id])
  Tenant           Tenant             @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tenant {
  id            String          @id @default(uuid())
  name          String
  defaultLocale String          @default("ar-EG")
  country       String
  createdAt     DateTime        @default(now())
  businessType  String          @default("general")
  Account       Account[]
  ActivityLog   ActivityLog[]
  Appointment   Appointment[]
  BrandSettings BrandSettings?
  Customer      Customer[]
  Employee      Employee[]
  Invoice       Invoice[]
  JournalEntry  JournalEntry[]
  PayrollRun    PayrollRun[]
  Product       Product[]
  PurchaseOrder PurchaseOrder[]
  StockMovement StockMovement[]
  Subscription  Subscription?
  User          User[]
  Warehouse     Warehouse[]
}

model TenantModuleOverride {
  tenantId  String
  moduleKey String
  enabled   Boolean

  @@id([tenantId, moduleKey])
}

model Translation {
  id     String @id @default(uuid())
  key    String
  locale String
  value  String

  @@unique([key, locale])
  @@index([locale])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  locale       String     @default("ar-EG")
  createdAt    DateTime   @default(now())
  Tenant       Tenant     @relation(fields: [tenantId], references: [id])
  UserRole     UserRole[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model UserRole {
  userId String
  roleId String
  Role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Warehouse {
  id         String       @id @default(uuid())
  tenantId   String
  nameKey    String
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  StockLevel StockLevel[]
  Tenant     Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum InvoiceChannel {
  MANUAL
  POS
}

enum InvoiceStatus {
  DRAFT
  POSTED
  VOID
}

enum PayrollStatus {
  DRAFT
  POSTED
}

enum ProductionOrderStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  RECEIPT
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  PRODUCTION_CONSUME
  PRODUCTION_OUTPUT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}
